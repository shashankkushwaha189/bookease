{
    "compilerOptions": {
        "target": "ESNext",
        "module": "CommonJS",
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "noImplicitAny": false,
        "noImplicitReturns": false,
        "noImplicitThis": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "src/modules/ai",
        "src/modules/ai_module_backup",
        "src/modules/appointment/appointment.engine.v2.ts",
        "src/routes",
        "src/routes/services-staff.routes.ts",
        "src/modules/user"
    ]
}