generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  timezone  String    @default("UTC")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessProfile BusinessProfile?
  config          TenantConfig[]
  services        Service[]
  staff           Staff[]
  users              User[]
  appointments       Appointment[]
  appointmentArchives AppointmentArchive[]
  apiTokens          ApiToken[]
  customers          Customer[]
  series          RecurringAppointmentSeries[]
  slotLocks       SlotLock[]
  aiSummaries     AiSummary[]
}

model BusinessProfile {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  businessName   String
  logoUrl        String?
  description    String?
  phone          String?
  email          String?
  address        String?
  brandColor     String   @default("#1A56DB")
  accentColor    String   @default("#7C3AED")
  policyText     String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  staff  Staff?

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum UserRole {
  ADMIN
  STAFF
}

model Service {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  durationMinutes Int
  bufferBefore    Int      @default(0)
  bufferAfter     Int      @default(0)
  price           Decimal?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  appointments       Appointment[]
  appointmentArchives AppointmentArchive[]
  staffServices      StaffService[]

  @@index([tenantId])
}

model Staff {
  id        String    @id @default(uuid())
  tenantId  String
  userId    String?   @unique
  name      String
  email     String?
  photoUrl  String?
  bio       String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  user                 User?                @relation(fields: [userId], references: [id])
  appointments         Appointment[]
  appointmentArchives   AppointmentArchive[]
  staffServices        StaffService[]
  timeOffs       StaffTimeOff[]
  weeklySchedule WeeklySchedule[]
  slotLocks      SlotLock[]

  @@index([tenantId])
}

model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
}

model WeeklySchedule {
  id        String       @id @default(uuid())
  staffId   String
  dayOfWeek Int // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  isWorking Boolean      @default(true)
  breaks    StaffBreak[]

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
}

model StaffBreak {
  id               String         @id @default(uuid())
  weeklyScheduleId String
  startTime        String
  endTime          String
  weeklySchedule   WeeklySchedule @relation(fields: [weeklyScheduleId], references: [id])
}

model StaffTimeOff {
  id        String    @id @default(uuid())
  staffId   String
  date      DateTime
  endDate   DateTime?
  reason    String?
  createdAt DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId, date])
}

model Appointment {
  id           String            @id @default(uuid())
  tenantId     String
  serviceId    String
  staffId      String
  customerId   String
  referenceId  String
  startTimeUtc DateTime
  endTimeUtc   DateTime
  status       AppointmentStatus @default(BOOKED)
  notes        String?
  createdBy    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  seriesId    String?
  seriesIndex Int?

  tenant   Tenant                      @relation(fields: [tenantId], references: [id])
  service  Service                     @relation(fields: [serviceId], references: [id])
  staff    Staff                       @relation(fields: [staffId], references: [id])
  customer Customer                    @relation(fields: [customerId], references: [id])
  series   RecurringAppointmentSeries? @relation(fields: [seriesId], references: [id])
  timeline AppointmentTimeline[]
  aiSummary AiSummary?

  @@index([tenantId, staffId, startTimeUtc])
  @@index([tenantId, startTimeUtc])
  @@index([referenceId])
  @@index([status, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

model AppointmentTimeline {
  id            String        @id @default(uuid())
  appointmentId String
  tenantId      String
  eventType     TimelineEvent
  performedBy   String? // userId or "SYSTEM" or "PUBLIC"
  note          String?
  metadata      Json? // e.g., { previousStatus, newStatus, overrideReason }
  createdAt     DateTime      @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@index([tenantId, createdAt])
}

enum TimelineEvent {
  CREATED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW_MARKED
  NOTE_ADDED
  AI_SUMMARY_GENERATED
  AI_SUMMARY_ACCEPTED
  AI_SUMMARY_DISCARDED
  ADMIN_OVERRIDE
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String?
  action        String // e.g., "appointment.cancel", "config.rollback"
  resourceType  String
  resourceId    String
  correlationId String
  before        Json? // state before change
  after         Json? // state after change
  ipAddress     String?
  reason        String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([correlationId])
}

model RecurringAppointmentSeries {
  id          String             @id @default(uuid())
  tenantId    String
  frequency   RecurringFrequency
  occurrences Int
  createdAt   DateTime           @default(now())

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  appointments        Appointment[]
  appointmentArchives AppointmentArchive[]

  @@index([tenantId])
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Customer {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  email        String
  phone        String?
  notes        String?
  tags         String[]
  consentGiven Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  appointments        Appointment[]
  appointmentArchives AppointmentArchive[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model SlotLock {
  id           String   @id @default(uuid())
  tenantId     String
  staffId      String
  startTimeUtc DateTime
  endTimeUtc   DateTime
  sessionToken String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([tenantId, staffId, startTimeUtc])
  @@index([expiresAt])
}

model ConsentRecord {
  id            String   @id @default(uuid())
  tenantId      String
  customerEmail String
  ipAddress     String
  consentText   String
  givenAt       DateTime @default(now())

  @@index([tenantId, customerEmail])
}

model TenantConfig {
  id        String   @id @default(uuid())
  tenantId  String
  version   Int      @default(1)
  config    Json
  createdBy String
  note      String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, version])
  @@index([tenantId, version])
}

model AppointmentArchive {
  id           String            @id @default(uuid())
  tenantId     String
  serviceId    String
  staffId      String
  customerId   String
  referenceId  String
  startTimeUtc DateTime
  endTimeUtc   DateTime
  status       AppointmentStatus
  notes        String?
  createdBy    String?
  createdAt    DateTime
  updatedAt    DateTime
  archivedAt   DateTime          @default(now())

  seriesId    String?
  seriesIndex Int?

  tenant   Tenant                      @relation(fields: [tenantId], references: [id])
  service  Service                     @relation(fields: [serviceId], references: [id])
  staff    Staff                       @relation(fields: [staffId], references: [id])
  customer Customer                    @relation(fields: [customerId], references: [id])
  series   RecurringAppointmentSeries? @relation(fields: [seriesId], references: [id])

  @@index([tenantId, staffId, startTimeUtc])
  @@index([tenantId, startTimeUtc])
  @@index([referenceId])
  @@index([status, createdAt])
  @@index([tenantId, status])
}

model ApiToken {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  tokenHash String
  lastUsed  DateTime?
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model AiSummary {
  id                 String       @id @default(uuid())
  appointmentId      String       @unique
  tenantId           String
  summary            String
  customerIntent     String?
  followUpSuggestion String?
  confidence         AiConfidence
  model              String
  accepted           Boolean?
  createdAt          DateTime     @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum AiConfidence {
  LOW
  MEDIUM
  HIGH
}
