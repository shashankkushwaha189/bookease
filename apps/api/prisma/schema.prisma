generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://bookease_qr29_user:WCcGifEPU4UM0ejeFH2341YTyToCAav5@dpg-d6iqtec50q8c73933oeg-a.oregon-postgres.render.com/bookease_qr29"
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  domain    String?   @unique
  timezone  String    @default("UTC")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  businessProfile BusinessProfile?
  config          TenantConfig[]
  services        Service[]
  staff           Staff[]
  users              User[]
  appointments       Appointment[]
  appointmentArchives AppointmentArchive[]
  apiTokens          ApiToken[]
  customers          Customer[]
  series          RecurringSeries[]
  slotLocks       SlotLock[]
  aiSummaries     AiSummary[]
  policyRules     PolicyRule[]
  customerTags    CustomerTag[]
  archivalConfigs ArchivalConfig[]
  archivalJobs    ArchivalJob[]
  importJobs      ImportJob[]
}

model BusinessProfile {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  businessName   String
  logoUrl        String?
  description    String?
  phone          String?
  email          String?
  address        String?
  brandColor     String   @default("#1A56DB")
  accentColor    String   @default("#7C3AED")
  policyText     String?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt DateTime?
  deletedAt    DateTime?
  
  // MFA fields
  mfaEnabled  Boolean  @default(false)
  mfaSecret   String?
  phoneNumber String?
  avatarUrl    String?
  preferences Json?
  lastSeenAt  DateTime?
  deviceId     String?
  
  // Verification fields
  smsVerificationCode String?
  smsCodeExpiresAt   DateTime?
  emailVerificationCode String?
  emailCodeExpiresAt  DateTime?
  recoveryCodes String?
  recoveryCodesGeneratedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  staff  Staff?
  @@unique([tenantId, email])
  @@index([tenantId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastAccessAt DateTime?
  deviceId     String?
  ipAddress    String?
  userAgent     String?

  @@index([userId])
}

enum UserRole {
  ADMIN
  STAFF
  USER
}

model Service {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  category        String   @default("General")
  durationMinutes Int
  bufferBefore    Int      @default(0)
  bufferAfter     Int      @default(0)
  price           Decimal?
  isActive        Boolean  @default(true)
  color           String?  // Hex color code
  requiresDeposit Boolean  @default(false)
  depositAmount   Decimal? // Deposit amount if required
  maxAdvanceBookingDays Int? // Maximum days in advance for booking
  minAdvanceBookingHours Int? // Minimum hours in advance for booking
  allowOnlineBooking Boolean @default(true) // Allow online booking
  requiresConfirmation Boolean @default(false) // Require confirmation
  tags            String[] // Service tags for search and categorization
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  appointments       Appointment[]
  recurringSeries    RecurringSeries[]
  appointmentArchives AppointmentArchive[]
  staffServices      StaffService[]
  slotLocks          SlotLock[]
  bookingAttempts    BookingAttempt[]

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, category])
}

model Staff {
  id               String              @id @default(uuid())
  tenantId         String
  userId           String?             @unique
  name             String
  email            String?             @unique
  photoUrl         String?             @db.Text
  bio              String?             @db.Text
  phone            String?             @db.Text
  title            String?             @db.Text
  department       String?             @db.Text
  hireDate         DateTime?
  isActive         Boolean             @default(true)
  maxConcurrentAppointments Int                 @default(1)
  requiresApproval Boolean             @default(false)
  commissionRate   Float?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  lastLoginAt       DateTime?

  // Relations
  user             User?               @relation(fields: [userId], references: [id])
  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  appointments     Appointment[]
  recurringSeries  RecurringSeries[]
  staffServices    StaffService[]
  weeklySchedule   WeeklySchedule[]
  timeOffs         StaffTimeOff[]
  dateOverrides    DateOverride[]
  slotLocks        SlotLock[]
  bookingAttempts   BookingAttempt[]
  customerNotes    CustomerNote[]
  appointmentArchives AppointmentArchive[]

  @@index([tenantId, email])
  @@index([tenantId, isActive])
  @@index([tenantId, deletedAt])
  @@unique([userId, tenantId])
}

model StaffService {
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
}

model WeeklySchedule {
  id        String       @id @default(uuid())
  staffId   String
  dayOfWeek Int // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String // "09:00"
  endTime   String // "17:00"
  isWorking Boolean      @default(true)
  maxAppointments Int? // Maximum appointments for this day
  breaks    StaffBreak[]

  staff Staff @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
}

model StaffBreak {
  id               String         @id @default(uuid())
  weeklyScheduleId String
  startTime        String
  endTime          String
  title            String? // Optional title for the break
  weeklySchedule   WeeklySchedule @relation(fields: [weeklyScheduleId], references: [id])
}

model StaffTimeOff {
  id        String    @id @default(uuid())
  staffId   String
  date      DateTime
  endDate   DateTime?
  reason    String?
  type      TimeOffType @default(PERSONAL)
  isPaid    Boolean   @default(true)
  createdAt DateTime  @default(now())

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId, date])
  @@index([staffId, type])
}

enum TimeOffType {
  VACATION
  SICK
  PERSONAL
  HOLIDAY
  TRAINING
}

model DateOverride {
  id        String    @id @default(uuid())
  staffId   String
  date      DateTime
  isWorking Boolean   @default(true)
  startTime String?   // HH:mm format
  endTime   String?   // HH:mm format
  reason    String?
  createdBy  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  staff Staff @relation(fields: [staffId], references: [id])

  @@index([staffId, date])
  @@index([date])
}

model Appointment {
  id           String            @id @default(uuid())
  tenantId     String
  serviceId    String
  staffId      String
  customerId   String
  referenceId  String            @unique
  startTimeUtc DateTime
  endTimeUtc   DateTime
  status       AppointmentStatus @default(BOOKED)
  notes        String?           @db.Text
  requiresConfirmation Boolean           @default(false)
  createdBy    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  completedAt  DateTime?
  seriesId     String?

  // Relations
  tenant   Tenant               @relation(fields: [tenantId], references: [id])
  service  Service              @relation(fields: [serviceId], references: [id])
  staff    Staff                @relation(fields: [staffId], references: [id])
  customer Customer             @relation(fields: [customerId], references: [id])
  series   RecurringSeries?     @relation(fields: [seriesId], references: [id])
  timeline AppointmentTimeline[]
  aiSummary AiSummary?
  slotLocks SlotLock[]
  timelineEvents AppointmentTimelineEvent[]

  @@index([tenantId, staffId, startTimeUtc])
  @@index([tenantId, startTimeUtc])
  @@index([referenceId])
  @@index([status, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
}

model BookingAttempt {
  id            String    @id @default(uuid())
  staffId       String
  serviceId      String
  customerId     String
  startTimeUtc   DateTime
  endTimeUtc     DateTime
  attemptAt     DateTime  @default(now())
  success        Boolean
  failureReason  String?
  lockId         String?

  staff    Staff    @relation(fields: [staffId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([staffId, attemptAt])
  @@index([success])
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

model AppointmentTimeline {
  id            String        @id @default(uuid())
  appointmentId String
  tenantId      String
  eventType     TimelineEvent
  performedBy   String? // userId or "SYSTEM" or "PUBLIC"
  note          String?
  metadata      Json? // e.g., { previousStatus, newStatus, overrideReason }
  createdAt     DateTime      @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId])
  @@index([tenantId, createdAt])
}

enum TimelineEvent {
  CREATED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  COMPLETED
  NO_SHOW_MARKED
  NOTE_ADDED
  AI_SUMMARY_GENERATED
  AI_SUMMARY_ACCEPTED
  AI_SUMMARY_DISCARDED
  ADMIN_OVERRIDE
}

model AuditLog {
  id            String   @id @default(uuid())
  tenantId      String
  userId        String?
  action        String // e.g., "appointment.cancel", "config.rollback"
  resourceType  String
  resourceId    String
  correlationId String
  before        Json? // state before change
  after         Json? // state after change
  ipAddress     String?
  reason        String?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([correlationId])
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model Customer {
  id           String        @id @default(uuid())
  tenantId     String
  name         String
  email        String
  phone        String?
  dateOfBirth  DateTime?
  gender       String?       // MALE, FEMALE, OTHER, PREFER_NOT_TO_SAY
  address      Json?         // Address object
  emergencyContact Json?     // Emergency contact object
  preferences  Json?         // Preferences object
  medicalInfo  Json?         // Medical information object
  status       String        @default("ACTIVE") // ACTIVE, INACTIVE, SUSPENDED, DELETED
  tags         String[]      @default([])
  notes        String?       @db.Text
  consentGiven Boolean       @default(false)
  consentDate  DateTime?
  source       String?       // WEBSITE, PHONE, WALK_IN, REFERRAL, SOCIAL_MEDIA, OTHER
  sourceDetails String?
  lastVisitDate DateTime?
  totalVisits  Int           @default(0)
  totalSpent   Float         @default(0)
  averageRating Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  // Relations
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  appointments        Appointment[]
  recurringSeries     RecurringSeries[]
  appointmentArchives AppointmentArchive[]
  slotLocks          SlotLock[]
  bookingAttempts   BookingAttempt[]
  customerNotes      CustomerNote[]
  consentRecords     ConsentRecord[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([status])
  @@index([deletedAt])
}

model CustomerNote {
  id          String   @id @default(uuid())
  customerId  String
  staffId     String
  type        String   // GENERAL, APPOINTMENT, PAYMENT, etc.
  title       String
  content     String
  isPrivate   Boolean  @default(false)
  isImportant Boolean  @default(false)
  tags        String[]
  attachments Json?    // Array of attachment objects
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  staff    Staff    @relation(fields: [staffId], references: [id])

  @@index([customerId, createdAt])
  @@index([staffId])
  @@index([type])
  @@index([isImportant])
}

model CustomerTag {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  color       String?  // Hex color code
  description String?
  isActive    Boolean  @default(true)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

model ConsentRecord {
  id            String   @id @default(uuid())
  customerId   String
  type          String   // PRIVACY_POLICY, TERMS_OF_SERVICE, etc.
  version       String
  given         Boolean
  givenAt       DateTime
  expiresAt     DateTime?
  ipAddress     String?
  userAgent     String?
  documentUrl   String?
  withdrawnAt   DateTime?
  withdrawnBy   String?
  notes         String?
  createdAt     DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId, type])
  @@index([givenAt])
  @@index([expiresAt])
}

model SlotLock {
  id           String   @id @default(uuid())
  tenantId     String
  staffId      String
  serviceId    String?
  customerId   String?
  startTimeUtc DateTime
  endTimeUtc   DateTime
  sessionToken String
  expiresAt    DateTime
  lockType     String   @default("BOOKING") // BOOKING, RESCHEDULE, MANUAL
  appointmentId String?
  createdAt    DateTime @default(now())

  // Relations
  tenant      Tenant @relation(fields: [tenantId], references: [id])
  staff       Staff  @relation(fields: [staffId], references: [id])
  service     Service? @relation(fields: [serviceId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@unique([tenantId, staffId, startTimeUtc])
  @@index([expiresAt])
}

model RecurringSeries {
  id                    String   @id @default(uuid())
  tenantId              String
  title                 String
  staffId               String
  serviceId             String
  customerId            String
  startTimeUtc          DateTime
  endTimeUtc            DateTime
  notes                 String?
  recurrenceRule        Json     // Complex recurrence pattern
  status                String   @default("ACTIVE") // ACTIVE, PAUSED, CANCELLED, COMPLETED
  totalOccurrences      Int      @default(0)
  completedOccurrences  Int      @default(0)
  cancelledOccurrences  Int      @default(0)
  nextOccurrence        DateTime?
  createdBy             String
  updatedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  staff        Staff        @relation(fields: [staffId], references: [id])
  service      Service      @relation(fields: [serviceId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  appointments Appointment[]

  @@index([tenantId, staffId])
  @@index([tenantId, status])
  @@index([nextOccurrence])
}

model TenantConfig {
  id        String   @id @default(uuid())
  tenantId  String
  version   Int      @default(1)
  config    Json
  createdBy String
  note      String?
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, version])
  @@index([tenantId, version])
}

model AppointmentArchive {
  id           String            @id @default(uuid())
  tenantId     String
  originalId   String            @unique
  customerId   String
  customerName String
  customerEmail String
  staffId      String
  staffName    String
  serviceId    String
  serviceName  String
  startTimeUtc DateTime
  endTimeUtc   DateTime
  status       AppointmentStatus
  referenceId  String
  notes        String?           @db.Text
  totalAmount  Float?
  archivedAt   DateTime          @default(now())
  archivedBy   String?

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  customer Customer  @relation(fields: [customerId], references: [id])
  staff    Staff     @relation(fields: [staffId], references: [id])
  service  Service   @relation(fields: [serviceId], references: [id])

  @@index([tenantId, archivedAt])
  @@index([customerId])
  @@index([staffId])
  @@index([serviceId])
  @@index([status])
  @@index([originalId])
}

model ArchivalConfig {
  id                 String   @id @default(uuid())
  tenantId           String
  archiveAfterMonths Int
  archiveStatuses    String[]
  excludeRecentDays  Int
  batchSize          Int
  scheduleCron       String
  enabled            Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  archivalJobs ArchivalJob[]

  @@unique([tenantId])
}

model ArchivalJob {
  id                  String   @id @default(uuid())
  tenantId            String
  status              String   // PENDING, RUNNING, COMPLETED, FAILED
  startedAt           DateTime?
  completedAt         DateTime?
  totalAppointments   Int
  archivedAppointments Int
  failedAppointments  Int
  errorMessage        String?
  metadata            Json?
  createdAt           DateTime @default(now())

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], map: "archival_job_tenant_fkey")
  config ArchivalConfig @relation(fields: [tenantId], references: [id], map: "archival_job_config_fkey")

  @@index([tenantId, status])
  @@index([createdAt])
}

model ApiToken {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  tokenHash String
  lastUsed  DateTime?
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model ImportJob {
  id          String   @id @default(uuid())
  tenantId    String
  importType  String   // CUSTOMERS, SERVICES, STAFF
  fileName    String
  fileSize    Int
  totalRows   Int
  status      String   // PENDING, PROCESSING, COMPLETED, FAILED, PARTIAL_SUCCESS
  options     Json     // Import options
  startedAt   DateTime @default(now())
  completedAt DateTime?
  processedRows Int    @default(0)
  successfulRows Int    @default(0)
  failedRows    Int    @default(0)
  skippedRows   Int    @default(0)
  duplicateRows Int    @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([startedAt])
}

model AiSummary {
  id                 String       @id @default(uuid())
  appointmentId      String       @unique
  tenantId           String
  summary            String
  customerIntent     String?
  followUpSuggestion String?
  confidence         AiConfidence
  model              String
  accepted           Boolean?
  createdAt          DateTime     @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

enum AiConfidence {
  LOW
  MEDIUM
  HIGH
}

model PolicyRule {
  id          String   @id @default(uuid())
  tenantId    String
  type        String   // CANCELLATION_WINDOW, RESCHEDULE_LIMIT, etc.
  name        String
  description String
  isActive    Boolean  @default(true)
  priority    Int      @default(50)
  config      Json     // Policy-specific configuration
  conditions  Json?    // Policy conditions
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  tenant               Tenant               @relation(fields: [tenantId], references: [id])
  policyOverrides      PolicyOverride[]

  @@index([tenantId, type])
  @@index([tenantId, isActive])
  @@index([priority])
}

model PolicyOverride {
  id                 String   @id @default(uuid())
  policyEvaluationId String   @unique
  policyId           String
  reason             String   // CUSTOMER_REQUEST, STAFF_ERROR, etc.
  reasonText         String
  userId             String
  userRole           String   // CUSTOMER, STAFF, ADMIN
  createdAt          DateTime @default(now())

  policyRule PolicyRule @relation(fields: [policyId], references: [id])

  @@index([policyEvaluationId])
  @@index([policyId])
  @@index([userId])
}

model PolicyRuleArchive {
  id          String   @id @default(uuid())
  policyId    String
  tenantId    String
  type        String
  name        String
  description String
  isActive    Boolean
  priority    Int
  config      Json
  conditions  Json?
  version     Int
  createdAt   DateTime
  updatedAt   DateTime
  createdBy   String?
  updatedBy   String?
  archivedAt  DateTime @default(now())
  archivedBy  String?

  @@index([policyId])
  @@index([archivedAt])
}

model AppointmentTimelineEvent {
  id            String   @id @default(uuid())
  appointmentId String
  eventType     String   // CREATED, RESCHEDULED, CANCELLED, etc.
  timestamp     DateTime @default(now())
  userId        String
  userRole      String   // CUSTOMER, STAFF, ADMIN, SYSTEM
  data          Json?    // Event-specific data
  correlationId String
  ipAddress     String?
  userAgent     String?
  sessionId     String?
  previousState Json?    // Previous appointment state
  newState      Json?    // New appointment state
  reason        String?
  isSystemGenerated Boolean @default(false)
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@index([appointmentId, timestamp])
  @@index([eventType])
  @@index([userId])
  @@index([correlationId])
  @@index([timestamp])
}

model AIUsageTracking {
  id            String   @id @default(uuid())
  correlationId String
  model         String
  prompt        String
  response      String
  tokensPrompt  Int
  tokensCompletion Int
  tokensTotal   Int
  processingTime Int     // in milliseconds
  confidence    Float?
  cost          Float?   // in USD
  success       Boolean  @default(true)
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([correlationId])
  @@index([model])
  @@index([createdAt])
  @@index([success])
}
