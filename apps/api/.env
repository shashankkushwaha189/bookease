# Database
DATABASE_URL="file:./dev.db"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3000
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5175

# Email (optional - for notifications)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR="./uploads"

# Demo Mode
DEMO_MODE=true
