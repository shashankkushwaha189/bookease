datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
  output          = "../src/generated/client"
}

model Tenant {
  id              String           @id @default(uuid())
  slug            String           @unique // used in URLs: bookease.com/t/my-clinic
  name            String
  timezone        String           @default("UTC") // IANA timezone: "Asia/Kolkata"
  isActive        Boolean          @default(true)
  deletedAt       DateTime? // soft delete
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  businessProfile BusinessProfile?
  users           User[]
}

model BusinessProfile {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  businessName   String
  logoUrl        String?
  description    String?
  phone          String?
  email          String?
  address        String?
  brandColor     String   @default("#1A56DB") // hex color
  accentColor    String   @default("#7C3AED")
  policyText     String? // shown before booking
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  email        String
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, email]) // email unique within a tenant
  @@index([tenantId])
}

enum UserRole {
  ADMIN
  STAFF
}

model ConsentRecord {
  id            String   @id @default(uuid())
  tenantId      String
  customerEmail String
  ipAddress     String
  consentText   String // exact policy text at time of consent
  givenAt       DateTime @default(now())

  @@index([tenantId, customerEmail])
}
