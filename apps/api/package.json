{
    "name": "@bookease/api",
    "version": "1.0.0",
    "private": true,
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "node build-minimal.js",
        "start": "node dist/index.js",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "db:seed": "ts-node prisma/seed.ts",
        "db:test": "ts-node scripts/test-db.ts",
        "db:seed:demo": "ts-node-dev --transpile-only prisma/seed-demo.ts",
        "db:reset:demo": "prisma db push --accept-data-loss && npm run db:seed:demo",
        "db:check": "ts-node src/scripts/check-db.ts",
        "db:tenants": "ts-node src/scripts/check-tenants.ts",
        "db:users": "ts-node src/scripts/check-users.ts",
        "db:test-tenant": "ts-node src/scripts/test-tenant.ts",
        "debug:appointments": "ts-node src/scripts/debug-appointments.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "demo:seed": "ts-node src/scripts/demo-seed.ts seed",
        "demo:reset": "ts-node src/scripts/demo-seed.ts reset",
        "demo:status": "ts-node src/scripts/demo-seed.ts status",
        "backup:create": "ts-node src/scripts/backup.ts create",
        "backup:restore": "ts-node src/scripts/backup.ts restore",
        "backup:list": "ts-node src/scripts/backup.ts list",
        "backup:cleanup": "ts-node src/scripts/backup.ts cleanup",
        "backup:verify": "ts-node src/scripts/backup.ts verify",
        "load-test:light": "ts-node src/scripts/load-test.ts light",
        "load-test:medium": "ts-node src/scripts/load-test.ts medium",
        "load-test:heavy": "ts-node src/scripts/load-test.ts heavy",
        "load-test:stress": "ts-node src/scripts/load-test.ts stress",
        "verify:all": "ts-node src/scripts/verify-functionality.ts",
        "verify:health": "curl -s http://localhost:3000/health | jq .",
        "verify:auth": "curl -X POST http://localhost:3000/auth/login -H \"Content-Type: application/json\" -d '{\"email\":\"admin@healthfirst.demo\",\"password\":\"demo123456\"}' | jq .",
        "verify:api": "curl -s http://localhost:3000/api/services -H \"x-tenant-id: healthfirst-demo\" | jq ."
    },
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "@types/nodemailer": "^7.0.11",
        "axios": "^1.6.0",
        "bcrypt": "^6.0.0",
        "compression": "latest",
        "cors": "latest",
        "csv-parse": "^5.5.6",
        "date-fns": "^4.1.0",
        "date-fns-tz": "^3.2.0",
        "express": "latest",
        "express-rate-limit": "latest",
        "helmet": "latest",
        "jsonwebtoken": "^9.0.3",
        "morgan": "latest",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.2",
        "pg": "^8.19.0",
        "uuid": "^13.0.0",
        "validator": "^13.11.0",
        "zod": "latest",
        "@bookease/logger": "workspace:*"
    },
    "devDependencies": {
        "@prisma/config": "^7.4.1",
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "latest",
        "@types/cors": "latest",
        "@types/csv-parse": "^1.2.2",
        "@types/express": "latest",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "latest",
        "@types/node": "latest",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.16.0",
        "@types/supertest": "latest",
        "@types/uuid": "^11.0.0",
        "@types/validator": "^13.11.9",
        "@vitest/coverage-v8": "latest",
        "copyfiles": "^2.4.1",
        "dotenv": "latest",
        "prisma": "^6.19.2",
        "supertest": "latest",
        "ts-node": "^10.9.2",
        "ts-node-dev": "latest",
        "typescript": "latest",
        "vitest": "latest"
    }
}